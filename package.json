{
  "name": "pi-fence",
  "version": "0.0.0",
  "description": "pi extension that processes fenced code blocks — renders diagrams, formats data, and more, via a pluggable processor registry.",
  "type": "module",
  "license": "MIT",
  "author": "Henrique Bastos <henrique@bastos.net>",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquebastos/pi-fence.git"
  },
  "bugs": {
    "url": "https://github.com/henriquebastos/pi-fence/issues"
  },
  "homepage": "https://github.com/henriquebastos/pi-fence#readme",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "fenced-code-block",
    "mermaid",
    "graphviz",
    "plantuml",
    "d2",
    "kroki",
    "diagrams",
    "visualization"
  ],
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/pi-fence/index.ts"
    ]
  },
  "scripts": {
    "check": "pnpm run check:links && pnpm run check:markdown",
    "check:links": "tsx scripts/check-links.ts",
    "check:markdown": "markdownlint-cli2",
    "fix:markdown": "markdownlint-cli2 --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:deps": "depcruise --config .dependency-cruiser.cjs extensions tests scripts",
    "verify:fast": "pnpm test && pnpm run check && pnpm run typecheck && pnpm run typecheck:deps",
    "test": "vitest run --exclude 'tests/integration/**' --exclude 'tests/render-image/**'",
    "test:watch": "vitest --exclude 'tests/integration/**' --exclude 'tests/render-image/**'",
    "test:live": "vitest run tests/integration tests/render-image",
    "test:all": "vitest run",
    "live:up": "tsx scripts/live-container.ts up",
    "live:down": "tsx scripts/live-container.ts down",
    "live:status": "tsx scripts/live-container.ts status",
    "live:exec": "tsx scripts/live-container.ts exec",
    "live:build": "tsx scripts/live-container.ts build",
    "refresh-fixtures": "tsx scripts/refresh-fixtures.ts",
    "render:verify": "tsx scripts/verify.ts",
    "render:gallery": "tsx scripts/render-gallery.ts",
    "sonar:scan": "pnpm exec sonar"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.67.68",
    "@types/node": "^25.6.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@xterm/addon-image": "0.10.0-beta.197",
    "dependency-cruiser": "^17.2.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "6.1.0-beta.197",
    "@sonar/scan": "^4.3.6",
    "markdownlint-cli2": "^0.22.0",
    "pixelmatch": "^7.1.0",
    "playwright-core": "^1.59.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
