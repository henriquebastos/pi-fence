{
  "name": "pi-fence",
  "version": "0.0.0",
  "description": "pi extension that processes fenced code blocks — renders diagrams, formats data, and more, via a pluggable processor registry.",
  "type": "module",
  "license": "MIT",
  "author": "Henrique Bastos <henrique@bastos.net>",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henriquebastos/pi-fence.git"
  },
  "bugs": {
    "url": "https://github.com/henriquebastos/pi-fence/issues"
  },
  "homepage": "https://github.com/henriquebastos/pi-fence#readme",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "fenced-code-block",
    "mermaid",
    "graphviz",
    "plantuml",
    "d2",
    "kroki",
    "diagrams",
    "visualization"
  ],
  "files": [
    "extensions",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/pi-fence/index.ts"
    ]
  },
  "scripts": {
    "feedback": "pnpm run feedback:fast",
    "feedback:fast": "pnpm test && pnpm run inspect:crap:ext && pnpm run lint:markdown && pnpm run lint:types && pnpm run lint:deps",
    "lint": "pnpm run lint:markdown",
    "lint:types": "tsc --noEmit",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs extensions tests scripts",
    "lint:markdown": "pnpm run lint:markdown:links && pnpm run lint:markdown:body",
    "lint:markdown:links": "tsx scripts/lint-markdown-links.ts",
    "lint:markdown:body": "markdownlint-cli2",
    "lint:markdown:fix": "markdownlint-cli2 --fix",
    "test": "vitest run --exclude 'tests/integration/**' --exclude 'tests/render-image/**' --coverage --coverage.provider=istanbul --coverage.reporter=json --coverage.reporter=text-summary --coverage.include='extensions/**/*.ts' --coverage.thresholds.statements=90 --coverage.thresholds.lines=90 --coverage.thresholds.functions=90 --coverage.thresholds.branches=75",
    "test:watch": "vitest --exclude 'tests/integration/**' --exclude 'tests/render-image/**'",
    "test:live": "tsx scripts/test-live.ts",
    "test:all": "vitest run",
    "inspect": "tsx scripts/inspect.ts",
    "inspect:coverage:nonlive": "vitest run --exclude 'tests/integration/**' --exclude 'tests/render-image/**' --coverage --coverage.provider=istanbul --coverage.reporter=json --coverage.reporter=text-summary --coverage.reportsDirectory=coverage/nonlive --coverage.include='extensions/**/*.ts' --coverage.include='scripts/**/*.ts' --coverage.include='tests/unit/**/*.ts' --coverage.include='tests/contract/**/*.ts' --coverage.include='tests/extension/**/*.ts' --coverage.include='tests/utilities/**/*.ts'",
    "inspect:crap": "pnpm run inspect:coverage:nonlive && pnpm run inspect:crap:nonlive",
    "inspect:crap:ext": "tsx scripts/inspect-crap-ext.ts",
    "inspect:crap:nonlive": "crap --json crap-report/nonlive/crap-report.json --html crap-report/nonlive/html --verbosity=log coverage/nonlive/coverage-final.json",
    "inspect:sonar": "pnpm run inspect:sonar:coverage && pnpm run inspect:sonar:scan && pnpm run inspect:sonar:report",
    "inspect:sonar:coverage": "vitest run --exclude 'tests/integration/**' --exclude 'tests/render-image/**' --coverage --coverage.provider=istanbul --coverage.reporter=lcov --coverage.reporter=text-summary --coverage.reportsDirectory=coverage/sonar --coverage.include='extensions/**/*.ts'",
    "inspect:sonar:scan": "pnpm exec sonar",
    "inspect:sonar:report": "tsx scripts/inspect-sonar-report.ts",
    "live:up": "tsx scripts/live.ts up",
    "live:down": "tsx scripts/live.ts down",
    "live:status": "tsx scripts/live.ts status",
    "live:exec": "tsx scripts/live.ts exec",
    "live:build": "tsx scripts/live.ts build",
    "refresh-fixtures": "tsx scripts/refresh-fixtures.ts",
    "render:verify": "tsx scripts/render-verify.ts",
    "render:gallery": "tsx scripts/render-gallery.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.67.68",
    "@sonar/scan": "^4.3.6",
    "@types/node": "^25.6.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-istanbul": "4.1.4",
    "@xterm/addon-image": "0.10.0-beta.197",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "6.1.0-beta.197",
    "crap-score": "1.2.0",
    "dependency-cruiser": "^17.2.0",
    "markdownlint-cli2": "^0.22.0",
    "pixelmatch": "^7.1.0",
    "playwright-core": "^1.59.1",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  }
}
